<UserControl x:Class="VocabTrainer.Presentation.Views.TrainingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VocabTrainer.Application.ViewModels"
             xmlns:loc="clr-namespace:VocabTrainer.Common"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- PRE-SESSION CONFIG SCREEN                                          -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsConfiguring, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="520" Margin="24">

                <TextBlock Text="{loc:Loc Training_StartTitle}" FontSize="30" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,24,0,6"/>
                <TextBlock Text="{loc:Loc Training_SelectMode}"
                           FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,32"/>

                <!-- Training Mode -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Training_ModeLabel}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,14"/>
                        <UniformGrid Columns="2" Rows="2">
                            <!-- Flashcard -->
                            <Border x:Name="FlashcardOption" Margin="4" CornerRadius="10"
                                    Cursor="Hand" Padding="16,14">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentMode}" Value="Flashcard">
                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SetModeFlashcardCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <Border CornerRadius="10" Width="48" Height="48" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#4A90D9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="Flashcard">
                                                        <Setter Property="Background" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="F" FontSize="22" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentMode}" Value="Flashcard">
                                                            <Setter Property="Foreground" Value="#4A90D9"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Text="{loc:Loc Training_Flashcard}" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Center" Margin="0,6,0,2">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="Flashcard">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="Show &amp; reveal" FontSize="11" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="Flashcard">
                                                        <Setter Property="Foreground" Value="#CCE8FF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Multiple Choice -->
                            <Border Margin="4" CornerRadius="10" Cursor="Hand" Padding="16,14">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentMode}" Value="MultipleChoice">
                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SetModeMultipleChoiceCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <Border CornerRadius="10" Width="48" Height="48" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#27AE60"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="MultipleChoice">
                                                        <Setter Property="Background" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="?" FontSize="22" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentMode}" Value="MultipleChoice">
                                                            <Setter Property="Foreground" Value="#27AE60"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Text="{loc:Loc Training_MultiChoice}" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Center" Margin="0,6,0,2">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="MultipleChoice">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="Pick the right answer" FontSize="11" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="MultipleChoice">
                                                        <Setter Property="Foreground" Value="#CCE8FF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Text Input -->
                            <Border Margin="4" CornerRadius="10" Cursor="Hand" Padding="16,14">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentMode}" Value="TextInput">
                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SetModeTextInputCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <Border CornerRadius="10" Width="48" Height="48" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#8E44AD"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="TextInput">
                                                        <Setter Property="Background" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="T" FontSize="22" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentMode}" Value="TextInput">
                                                            <Setter Property="Foreground" Value="#8E44AD"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Text="{loc:Loc Training_TextInput}" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Center" Margin="0,6,0,2">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="TextInput">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="Type the translation" FontSize="11" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="TextInput">
                                                        <Setter Property="Foreground" Value="#CCE8FF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Mixed -->
                            <Border Margin="4" CornerRadius="10" Cursor="Hand" Padding="16,14">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentMode}" Value="Mixed">
                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SetModeMixedCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <Border CornerRadius="10" Width="48" Height="48" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E67E22"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="Mixed">
                                                        <Setter Property="Background" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="*" FontSize="24" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentMode}" Value="Mixed">
                                                            <Setter Property="Foreground" Value="#E67E22"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Text="{loc:Loc Training_Mixed}" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Center" Margin="0,6,0,2">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="Mixed">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="Random each card" FontSize="11" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentMode}" Value="Mixed">
                                                        <Setter Property="Foreground" Value="#CCE8FF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Words per session slider -->
                <Border Style="{StaticResource Card}" Margin="8,0,8,8">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Loc Training_WordsPerSession}"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Border Grid.Column="1" Background="{DynamicResource PrimaryBrush}"
                                    CornerRadius="6" Padding="12,4">
                                <TextBlock Text="{Binding WordsPerSession}" FontSize="16"
                                           FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </Grid>
                        <Slider Value="{Binding WordsPerSession}" Minimum="5" Maximum="50"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                Margin="0,12,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="5" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBlock Text="25" Margin="98,0,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBlock Text="50" Margin="98,0,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Start button -->
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding StartSessionCommand}"
                        Content="{loc:Loc Training_StartSession}"
                        Height="54" FontSize="17" Margin="8,8,8,32"/>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- SESSION COMPLETE                                                   -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Visibility="{Binding SessionComplete, Converter={StaticResource BoolToVisibility}}"
                HorizontalAlignment="Center" VerticalAlignment="Center" Width="460">
            <Border Style="{StaticResource Card}" Padding="40">
                <StackPanel HorizontalAlignment="Center">
                    <!-- Theme-aware trophy icon -->
                    <Border Width="80" Height="80" CornerRadius="40"
                            Background="{DynamicResource AccentBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,4">
                        <TextBlock Text="🏆" FontSize="38"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{loc:Loc Training_Complete}" FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,10,0,4"/>
                    <TextBlock Text="{loc:Loc Training_CompleteSubtitle}"
                               FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,24"/>
                    <!-- Row 1: Correct + Wrong -->
                    <UniformGrid Rows="1" Columns="2" Margin="0,0,0,8">
                        <Border Background="{DynamicResource HoverBrush}" CornerRadius="10"
                                Padding="20,14" Margin="0,0,4,0">
                            <StackPanel>
                                <TextBlock Text="{Binding SessionCorrect}" FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc Training_Correct}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource HoverBrush}" CornerRadius="10"
                                Padding="20,14" Margin="4,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding SessionWrong}" FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource DangerBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{loc:Loc Training_Wrong}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                    <!-- Row 2: Accuracy centered -->
                    <Border Background="{DynamicResource HoverBrush}" CornerRadius="10"
                            Padding="20,14" Margin="0,0,0,20"
                            HorizontalAlignment="Center" MinWidth="180">
                        <StackPanel>
                            <TextBlock Text="{Binding SessionAccuracy, StringFormat={}{0:F1}%}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="#4A90D9" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc Training_Accuracy}" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <TextBlock Text="{loc:Loc Training_Time}" FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding SessionDuration}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding RestartSessionCommand}" Width="220"
                            Content="{loc:Loc Training_NewSession}"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ACTIVE TRAINING                                                    -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Grid Margin="24">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsConfiguring}" Value="False"/>
                                <Condition Binding="{Binding SessionComplete}" Value="False"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: mode label + timer -->
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Mode: {0}  •  Card {1} of {2}">
                                <Binding Path="CurrentMode"/>
                                <Binding Path="Progress"/>
                                <Binding Path="TotalCards"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <Border Background="#E8F8F0" CornerRadius="5" Padding="8,3" Margin="0,0,6,0">
                            <TextBlock Text="{Binding SessionCorrect, StringFormat=✓ {0}}"
                                       Foreground="#27AE60" FontWeight="SemiBold" FontSize="12"/>
                        </Border>
                        <Border Background="#FDEDEC" CornerRadius="5" Padding="8,3" Margin="0,0,6,0">
                            <TextBlock Text="{Binding SessionWrong, StringFormat=✗ {0}}"
                                       Foreground="#E74C3C" FontWeight="SemiBold" FontSize="12"/>
                        </Border>
                        <Border Background="#EBF5FB" CornerRadius="5" Padding="8,3">
                            <TextBlock Text="{Binding SessionAccuracy, StringFormat={}{0:F1}%}"
                                       Foreground="#4A90D9" FontWeight="SemiBold" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="1" Background="{DynamicResource WarningBrush}" CornerRadius="8"
                        Padding="14,6" Visibility="{Binding TimerActive, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding TimerRemaining, StringFormat=⏱ {0}s}"
                               Foreground="White" FontSize="16" FontWeight="Bold"/>
                </Border>
            </Grid>

            <!-- Progress bar -->
            <ProgressBar Grid.Row="1" Style="{StaticResource ModernProgressBar}"
                         Value="{Binding Progress}" Maximum="{Binding TotalCards}"
                         Margin="0,0,0,10"/>

            <!-- Card -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                MaxWidth="600" Margin="0,20">

                        <!-- Question (all modes) -->
                        <TextBlock Text="{loc:Loc Training_Question}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding QuestionText}" FontSize="44" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <TextBlock Text="{Binding CurrentCard.ExampleSentence}"
                                   FontSize="14" FontStyle="Italic"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" MaxWidth="480" Margin="0,0,0,12"
                                   Visibility="{Binding CurrentCard.ExampleSentence,
                                                Converter={StaticResource NullToVisibility}}"/>

                        <TextBlock Text="{Binding CurrentCard.Tags, StringFormat=🏷 {0}}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,20"
                                   Visibility="{Binding CurrentCard.Tags,
                                                Converter={StaticResource NullToVisibility}}"/>

                        <!-- ── FLASHCARD: revealed answer ── -->
                        <StackPanel Visibility="{Binding ShowAnswer, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ShowAnswer}" Value="True"/>
                                                <Condition Binding="{Binding EffectiveMode}" Value="Flashcard"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Separator Margin="40,0,40,16"/>
                            <TextBlock Text="{loc:Loc Training_Answer}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding AnswerText}" FontSize="34" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- ── MULTIPLE CHOICE: option buttons ── -->
                        <ItemsControl ItemsSource="{Binding MultipleChoiceOptions}" Margin="0,8,0,0">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding EffectiveMode}" Value="MultipleChoice">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,5" Height="50" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding DataContext.SelectMultipleChoiceCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="8" Padding="20,0">
                                                    <Border.Background>
                                                        <MultiBinding Converter="{StaticResource McColor}">
                                                            <Binding Path="ShowResult"/>
                                                            <Binding Path="IsCorrect"/>
                                                            <Binding Path="IsSelected"/>
                                                        </MultiBinding>
                                                    </Border.Background>
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="{Binding Text}" FontSize="16"
                                                   Foreground="White" FontWeight="SemiBold"
                                                   TextAlignment="Center" TextWrapping="Wrap"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- ── TEXT INPUT: text box + feedback ── -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding EffectiveMode}" Value="TextInput">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="18" Padding="12,10" Margin="0,8,0,0"
                                     HorizontalAlignment="Stretch"
                                     IsEnabled="{Binding InputValidated, Converter={StaticResource BoolToInverseVisibility}}"
                                     ToolTip="{loc:Loc Training_TypeHint}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding ValidateInputCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <TextBlock Text="{Binding InputFeedback}" FontSize="16" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,14,0,0"
                                       Visibility="{Binding InputValidated, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding InputCorrect}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding InputCorrect}" Value="False">
                                                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Action buttons -->
            <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,14,0,0">

                <!-- FLASHCARD: Show Answer button (before reveal) -->
                <Button Command="{Binding RevealAnswerCommand}" Width="220" Height="48" Margin="0,0,0,10">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SecondaryButton}" TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding EffectiveMode}" Value="Flashcard"/>
                                        <Condition Binding="{Binding ShowAnswer}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Content><loc:Loc Key="Training_ShowAnswer"/></Button.Content>
                </Button>

                <!-- FLASHCARD: Knew It / Didn't Know (after reveal) -->
                <StackPanel Orientation="Horizontal">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding EffectiveMode}" Value="Flashcard"/>
                                        <Condition Binding="{Binding ShowAnswer}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button Style="{StaticResource SuccessButton}" Command="{Binding KnewItCommand}"
                            Width="180" Height="50" Margin="0,0,16,0">
                        <Button.Content><loc:Loc Key="Training_KnewIt"/></Button.Content>
                    </Button>
                    <Button Style="{StaticResource DangerButton}" Command="{Binding DidNotKnowCommand}"
                            Width="180" Height="50">
                        <Button.Content><loc:Loc Key="Training_DidNotKnow"/></Button.Content>
                    </Button>
                </StackPanel>

                <!-- TEXT INPUT: Check Answer button -->
                <Button Command="{Binding ValidateInputCommand}" Width="220" Height="48">
                    <Button.Style>
                        <Style BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding EffectiveMode}" Value="TextInput"/>
                                        <Condition Binding="{Binding InputValidated}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Content><loc:Loc Key="Training_CheckAnswer"/></Button.Content>
                </Button>

            </StackPanel>
        </Grid>

        <!-- Loading -->
        <Border Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Loading..." Foreground="White" FontSize="18" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="VocabTrainer.Presentation.Views.WordManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:VocabTrainer.Common"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Grid Grid.Row="0" Margin="8,8,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Style="{StaticResource HeadingText}"
                       Text="{loc:Loc Words_Title}" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource SecondaryButton}" Command="{Binding ExportCsvCommand}"
                        Margin="0,0,8,0" Content="{loc:Loc Words_ExportCsv}"/>
                <Button Style="{StaticResource SecondaryButton}" Command="{Binding ExportExcelCommand}"
                        Margin="0,0,12,0" Content="{loc:Loc Words_ExportExcel}"/>
                <Button Style="{StaticResource PrimaryButton}" Command="{Binding AddNewCommand}"
                        Content="{loc:Loc Words_AddNew}"/>
            </StackPanel>
        </Grid>

        <!-- ── Filters ── -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14,10" Margin="8,0,8,4">
            <WrapPanel VerticalAlignment="Center">
                <TextBox Style="{StaticResource ModernTextBox}" Width="220" Margin="0,0,10,0"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                <ComboBox ItemsSource="{Binding AllTags}" SelectedItem="{Binding FilterTag}"
                          Width="140" Margin="0,0,10,0"/>
                <ComboBox SelectedItem="{Binding SortMode}" Width="140" Margin="0,0,14,0">
                    <ComboBoxItem Content="German"/>
                    <ComboBoxItem Content="Difficulty"/>
                    <ComboBoxItem Content="NextReview"/>
                    <ComboBoxItem Content="ReviewCount"/>
                </ComboBox>
                <Border Background="{DynamicResource HoverBrush}" CornerRadius="6" Padding="10,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Words.Count}" FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text=" words" FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </Border>

        <!-- ── Bulk action toolbar ── -->
        <Border Grid.Row="2" Margin="8,0,8,4" CornerRadius="8" Padding="12,8"
                Background="{DynamicResource HoverBrush}">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource SecondaryButton}" Padding="10,5" Margin="0,0,6,0"
                        Command="{Binding SelectAllCommand}" Content="{loc:Loc Words_SelectAll}"/>
                <Button Style="{StaticResource SecondaryButton}" Padding="10,5" Margin="0,0,6,0"
                        Command="{Binding ClearSelectionCommand}" Content="{loc:Loc Words_Clear}"/>
                <Button Style="{StaticResource SecondaryButton}" Padding="10,5" Margin="0,0,6,0"
                        Command="{Binding InvertSelectionCommand}" Content="{loc:Loc Words_Invert}"/>
                <Button Style="{StaticResource DangerButton}" Padding="10,5"
                        Command="{Binding DeleteSelectedCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{loc:Loc Words_DeleteSelected}" VerticalAlignment="Center"/>
                        <TextBlock Text=" (" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedCount}" VerticalAlignment="Center"/>
                        <TextBlock Text=")" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- ── Table + Edit panel ── -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0" Margin="8,0,4,8">
                <DataGrid ItemsSource="{Binding Words}"
                          MouseDoubleClick="DataGrid_MouseDoubleClick"
                          SelectionMode="Single" SelectionUnit="FullRow">
                    <DataGrid.Columns>

                        <!-- Checkbox (no header) -->
                        <DataGridTemplateColumn Width="42" CanUserSort="False" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay,
                                                          UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="{loc:Loc Words_German}"      Binding="{Binding Card.German}"    MinWidth="120" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="{loc:Loc Words_English}"     Binding="{Binding Card.English}"   MinWidth="120"/>
                        <DataGridTextColumn Header="{loc:Loc Words_Ukrainian}"   Binding="{Binding Card.Ukrainian}"  MinWidth="120"/>
                        <DataGridTextColumn Header="{loc:Loc Words_Tags}"        Binding="{Binding Card.Tags}"      MinWidth="90"/>
                        <DataGridTextColumn Header="{loc:Loc Words_Reviews}"     Binding="{Binding Card.ReviewCount}" MinWidth="65"/>
                        <DataGridTextColumn Header="{loc:Loc Words_SuccessRate}"     Binding="{Binding Card.SuccessRate, StringFormat={}{0:F1}%}" MinWidth="70"/>
                        <DataGridTextColumn Header="{loc:Loc Words_NextReview}" Binding="{Binding Card.NextReview, StringFormat=dd.MM.yyyy}" MinWidth="100"/>

                        <DataGridTemplateColumn Header="{loc:Loc Words_Actions}" MinWidth="90" CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="✏️" ToolTip="Edit" Margin="2,0" Cursor="Hand" FontSize="15"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource PrimaryBrush}"
                                                Command="{Binding DataContext.EditCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="🗑️" ToolTip="Delete" Margin="2,0" Cursor="Hand" FontSize="15"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource DangerBrush}"
                                                Command="{Binding DataContext.DeleteCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="↺" ToolTip="Reset stats" Margin="2,0" Cursor="Hand" FontSize="15"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource TextSecondaryBrush}"
                                                Command="{Binding DataContext.ResetStatsCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Edit / Add panel -->
            <Border Grid.Column="1" Width="330" Margin="4,0,8,8"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                <Border Style="{StaticResource Card}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="17" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{loc:Loc Words_EditWord}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EditingWord.Id}" Value="0">
                                                    <Setter Property="Text" Value="{loc:Loc Words_NewWord}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Grid.Column="1" Content="✕" Background="Transparent" BorderThickness="0"
                                        Command="{Binding CancelEditCommand}" Cursor="Hand"
                                        FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Grid>

                            <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Words_German}"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding EditingWord.German, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Words_EnglishHint}"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding EditingWord.English, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Words_UkrainianHint}"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding EditingWord.Ukrainian, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Words_Example}"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding EditingWord.ExampleSentence, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" AcceptsReturn="True" Height="70"
                                     VerticalScrollBarVisibility="Auto"/>

                            <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Words_Tags}"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding EditingWord.Tags, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,6,0,16" TextWrapping="Wrap"
                                       Text="{loc:Loc Words_VariantHint}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource SuccessButton}"
                                        Command="{Binding SaveCommand}" Margin="0,0,6,0"
                                        Content="{loc:Loc Words_Save}"/>
                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CancelEditCommand}" Content="{loc:Loc Words_Cancel}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Border>
        </Grid>

        <!-- ── Status bar ── -->
        <Border Grid.Row="4" Margin="8,0,8,4" Padding="12,6" CornerRadius="6"
                Background="{DynamicResource HoverBrush}"
                Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}">
            <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Border>
    </Grid>
</UserControl>

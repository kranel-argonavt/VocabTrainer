<UserControl x:Class="VocabTrainer.Presentation.Views.ImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:VocabTrainer.Common"
             Background="{DynamicResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Style="{StaticResource HeadingText}"
                       Text="{loc:Loc Import_Title}"/>

            <!-- Step 1: File -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource HeadingText}" FontSize="16"
                               Text="{loc:Loc Import_Step1}"/>

                    <!-- File type radio buttons — use bool properties, NOT enum -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <RadioButton Content="Excel (.xlsx)"
                                     IsChecked="{Binding IsExcel}"
                                     Margin="0,0,20,0" FontSize="14"
                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <RadioButton Content="CSV"
                                     IsChecked="{Binding IsCsv}"
                                     FontSize="14"
                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource ModernTextBox}"
                                 Text="{Binding SelectedFilePath}" IsReadOnly="True"
                                 Margin="0,0,10,0" FontSize="13"/>
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseFileCommand}"
                                Content="{loc:Loc Import_Browse}"/>
                    </Grid>

                    <!-- CSV Options -->
                    <StackPanel Margin="0,12,0,0"
                                Visibility="{Binding IsCsv, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{loc:Loc Import_Separator}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,0"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Width="60"
                                     Text="{Binding CsvSeparator}" MaxLength="1"/>
                        </StackPanel>
                    </StackPanel>

                    <CheckBox IsChecked="{Binding HasHeaderRow}"
                              Content="{loc:Loc Import_HasHeader}"
                              Margin="0,12,0,0" FontSize="13"
                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Step 2: Column Mapping (Excel only) -->
            <Border Style="{StaticResource Card}"
                    Visibility="{Binding IsExcel, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Style="{StaticResource HeadingText}" FontSize="16"
                               Text="{loc:Loc Import_Step2}"/>
                    <WrapPanel>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Words_German}"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Width="80" Text="{Binding GermanColumn}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Words_English}"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Width="80" Text="{Binding EnglishColumn}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Words_Ukrainian}"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Width="80" Text="{Binding UkrainianColumn}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Words_Example}"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Width="80" Text="{Binding ExampleColumn}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Words_Tags}"/>
                            <TextBox Style="{StaticResource ModernTextBox}" Width="80" Text="{Binding TagsColumn}"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Margin="8,0,8,16">
                <Button Style="{StaticResource SecondaryButton}"
                        Command="{Binding PreviewCommand}"
                        Content="{loc:Loc Import_Preview}" Margin="0,0,12,0" Padding="16,8"/>
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding ImportCommand}"
                        Content="{loc:Loc Import_DoImport}" Padding="16,8"
                        IsEnabled="{Binding Previewed}"/>
                <Button Style="{StaticResource SecondaryButton}"
                        Command="{Binding ResetCommand}"
                        Content="{loc:Loc Import_Reset}" Padding="16,8" Margin="12,0,0,0"/>
            </StackPanel>

            <!-- Preview Results -->
            <Border Style="{StaticResource Card}"
                    Visibility="{Binding Previewed, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Style="{StaticResource HeadingText}" FontSize="16"
                               Text="{loc:Loc Import_PreviewTitle}"/>
                    <WrapPanel Margin="0,0,0,12">
                        <Border Background="#E8F8F0" CornerRadius="8" Padding="12,8" Margin="0,0,10,0">
                            <TextBlock Text="{Binding PreviewResult.Imported, StringFormat=📥 {0} to import}"
                                       Foreground="#27AE60" FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="#FEF9E7" CornerRadius="8" Padding="12,8" Margin="0,0,10,0">
                            <TextBlock Text="{Binding PreviewResult.Skipped, StringFormat=⊘ {0} duplicates}"
                                       Foreground="#F39C12" FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="#FDEDEC" CornerRadius="8" Padding="12,8">
                            <TextBlock Text="{Binding PreviewResult.Errors, StringFormat=✗ {0} errors}"
                                       Foreground="#E74C3C" FontWeight="SemiBold"/>
                        </Border>
                    </WrapPanel>
                    <ItemsControl ItemsSource="{Binding ErrorMessages}" Margin="0,0,0,10"
                                  Visibility="{Binding ErrorMessages.Count, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#E74C3C" FontSize="12" Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <DataGrid ItemsSource="{Binding PreviewWords}" MaxHeight="300" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="German" Binding="{Binding German}" MinWidth="120"/>
                            <DataGridTextColumn Header="English" Binding="{Binding English}" MinWidth="120"/>
                            <DataGridTextColumn Header="Ukrainian" Binding="{Binding Ukrainian}" MinWidth="120"/>
                            <DataGridTextColumn Header="Tags" Binding="{Binding Tags}" MinWidth="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

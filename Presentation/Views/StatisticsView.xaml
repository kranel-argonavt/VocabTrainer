<UserControl x:Class="VocabTrainer.Presentation.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:VocabTrainer.Common"
             Background="{DynamicResource BackgroundBrush}"
             DataContextChanged="OnDataContextChanged">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20,16,20,24">

            <!-- ── Header ── -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{loc:Loc Stats_Title}" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                        Command="{Binding RefreshCommand}" Content="{loc:Loc Stats_Refresh}"/>
            </Grid>

            <!-- ── KPI row 1: 4 big cards ── -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Words -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,5,0" Padding="14,16">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Background="#3B82F6" CornerRadius="10" Width="40" Height="40"
                                HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock Text="W" FontSize="18" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding GlobalStats.TotalWords}" FontSize="30" FontWeight="Bold"
                                   Foreground="#3B82F6" HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Loc Stats_TotalWords}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Learned -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="5,0,5,0" Padding="14,16">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Background="#22C55E" CornerRadius="10" Width="40" Height="40"
                                HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock Text="✓" FontSize="18" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding GlobalStats.LearnedWords}" FontSize="30" FontWeight="Bold"
                                   Foreground="#22C55E" HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Loc Stats_Learned}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Accuracy -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Margin="5,0,5,0" Padding="14,16">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Background="#A855F7" CornerRadius="10" Width="40" Height="40"
                                HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock Text="%" FontSize="18" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding GlobalStats.OverallAccuracy, StringFormat={}{0:F1}%}"
                                   FontSize="30" FontWeight="Bold"
                                   Foreground="#A855F7" HorizontalAlignment="Center"/>
                        <TextBlock Text="{loc:Loc Stats_Accuracy}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Streak -->
                <Border Grid.Column="3" Style="{StaticResource Card}" Margin="5,0,0,0" Padding="14,16">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Background="#F97316" CornerRadius="10" Width="40" Height="40"
                                HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock Text="▲" FontSize="16" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding GlobalStats.Streak}" FontSize="30" FontWeight="Bold"
                                       Foreground="#F97316"/>
                            <TextBlock Text="d" FontSize="18" FontWeight="Bold" Foreground="#F97316"
                                       VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                        </StackPanel>
                        <TextBlock Text="{loc:Loc Stats_Streak}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── KPI row 2: 3 compact cards ── -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Due today -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,5,0" Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#EF4444" CornerRadius="8"
                                Width="40" Height="40" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="!" FontSize="20" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding GlobalStats.DueToday}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource DangerBrush}"/>
                            <TextBlock Text="{loc:Loc Stats_DueToday}" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Total reviews -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="5,0,5,0" Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#0EA5E9" CornerRadius="8"
                                Width="40" Height="40" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="↻" FontSize="20" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding GlobalStats.TotalReviews}" FontSize="22" FontWeight="Bold"
                                       Foreground="#0EA5E9"/>
                            <TextBlock Text="{loc:Loc Stats_TotalReviews}" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Not started -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Margin="5,0,0,0" Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#14B8A6" CornerRadius="8"
                                Width="40" Height="40" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="★" FontSize="18" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding GlobalStats.NewWords}" FontSize="22" FontWeight="Bold"
                                       Foreground="#14B8A6"/>
                            <TextBlock Text="{loc:Loc Stats_NotStarted}" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── Vocabulary progress bar ── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12" Padding="18,14">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{loc:Loc Stats_VocabProgress}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding GlobalStats.LearnedPercent, StringFormat={}{0:F1}%}"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#22C55E"/>
                            <TextBlock Text=" " FontSize="13"/>
                            <TextBlock Text="{loc:Loc Stats_ProgressLabel}" FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Height="14">
                        <Border CornerRadius="7" Background="{DynamicResource HoverBrush}"/>
                        <ProgressBar Minimum="0"
                                     Maximum="{Binding GlobalStats.TotalWords}"
                                     Value="{Binding GlobalStats.LearnedWords}"
                                     Height="14" Background="Transparent" BorderThickness="0"
                                     Foreground="#22C55E"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Ellipse Width="9" Height="9" Fill="#22C55E" VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Loc Stats_Learned}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,16,0"/>
                        <Ellipse Width="9" Height="9" Fill="{DynamicResource WarningBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Loc Stats_InProgress}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,16,0"/>
                        <Ellipse Width="9" Height="9" Fill="{DynamicResource HoverBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Loc Stats_NotStarted}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Daily Activity ── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12" Padding="20,16">
                <StackPanel>

                    <!-- Header -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{loc:Loc Stats_DailyActivity}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="BtnPrev" Content="&#8249;" Width="26" Height="26"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="0" FontSize="16" Margin="0,0,4,0"
                                    Click="BtnPrev_Click"/>
                            <TextBlock x:Name="TxtMonthYear" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" MinWidth="100" TextAlignment="Center"/>
                            <Button x:Name="BtnNext" Content="&#8250;" Width="26" Height="26"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="0" FontSize="16" Margin="4,0,0,0"
                                    Click="BtnNext_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Chart canvas injected here -->
                    <StackPanel x:Name="ChartHost"/>

                </StackPanel>
            </Border>



        </StackPanel>
    </ScrollViewer>
</UserControl>

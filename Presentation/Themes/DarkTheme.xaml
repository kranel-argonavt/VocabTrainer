<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryColor">#5BA8EE</Color>
    <Color x:Key="PrimaryDarkColor">#4A90D9</Color>
    <Color x:Key="AccentColor">#2ECC71</Color>
    <Color x:Key="DangerColor">#E74C3C</Color>
    <Color x:Key="WarningColor">#F39C12</Color>
    <Color x:Key="BackgroundColor">#1A1A2E</Color>
    <Color x:Key="CardBackground">#16213E</Color>
    <Color x:Key="SidebarBackground">#0F3460</Color>
    <Color x:Key="TextPrimaryColor">#E0E0E0</Color>
    <Color x:Key="TextSecondaryColor">#9E9E9E</Color>
    <Color x:Key="BorderColor">#2D2D4E</Color>
    <Color x:Key="HoverColor">#1E2A4A</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarBackground}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="NavTextBrush" Color="White"/>
    <SolidColorBrush x:Key="NavHoverBrush" Color="#1A3A6E"/>
    <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="#1E3A2F"/>
    <SolidColorBrush x:Key="SuccessForegroundBrush" Color="#6EE7B7"/>

    <!-- DataGrid specific -->
    <SolidColorBrush x:Key="DataGridLineBrush"       Color="#3A3A5E"/>
    <SolidColorBrush x:Key="DataGridAltRowBrush"     Color="#1E1E38"/>
    <SolidColorBrush x:Key="DataGridHeaderBrush"     Color="#0F1729"/>
    <SolidColorBrush x:Key="DataGridHoverBrush"      Color="#253352"/>
    <SolidColorBrush x:Key="DataGridSelectedBrush"   Color="#1A3A6E"/>

</ResourceDictionary>
